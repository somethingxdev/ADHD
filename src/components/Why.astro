---
import type { SvgComponent } from 'astro/types';
import ScanEyeIcon from '@/icons/scan-eye.svg';
import SchoolIcon from '@/icons/school.svg';
import BusinessIcon from '@/icons/business.svg';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from './starwind/card';
import data from '@/data/why.yaml';

const iconMap: Record<string, SvgComponent> = {
  'scan-eye': ScanEyeIcon,
  school: SchoolIcon,
  business: BusinessIcon,
};

const items = data.items.map((item: { icon: string; title: string; description: string }) => ({
  ...item,
  icon: iconMap[item.icon] || ScanEyeIcon,
}));
---

<section class="py-10 lg:py-20">
  <div class="container">
    <h2 class="md:text-center text-3xl md:text-4xl lg:text-5xl font-semibold mb-6 md:mb-12">{data.title}</h2>
    <div class="grid md:grid-cols-3 gap-5 lg:gap-8">
      {
        items.map((item: { icon: SvgComponent; title: string; description: string }) => (
          <Card class="gap-4 md:gap-12">
            <CardHeader>
              <item.icon />
            </CardHeader>
            <CardContent>
              <CardTitle class="mb-3">{item.title}</CardTitle>
              <CardDescription>{item.description}</CardDescription>
            </CardContent>
          </Card>
        ))
      }
    </div>
  </div>
</section>
