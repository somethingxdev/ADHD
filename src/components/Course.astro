---
import Tabs from './starwind/tabs/Tabs.astro';
import TabsList from './starwind/tabs/TabsList.astro';
import TabsTrigger from './starwind/tabs/TabsTrigger.astro';
import TabsContent from './starwind/tabs/TabsContent.astro';
import Accordion from './starwind/accordion/Accordion.astro';
import AccordionItem from './starwind/accordion/AccordionItem.astro';
import AccordionTrigger from './starwind/accordion/AccordionTrigger.astro';
import AccordionContent from './starwind/accordion/AccordionContent.astro';
import { Star } from '@lucide/astro';
import course from '../data/course.yaml';
import { Markdown } from '@astropub/md'
const { title, subtitle, lessons } = course;
---

<section class="py-10 lg:py-20">
  <div class="container">
    <h2 class="text-3xl md:text-4xl lg:text-5xl font-semibold mb-6 lg:mb-12 md:max-w-3xl">
      {title}
    </h2>

    <!-- Desktop: Tabs -->
    <Tabs defaultValue="1" class="hidden md:grid grid-cols-2 gap-8">
      <TabsList class="flex flex-col items-stretch gap-2 bg-transparent p-0 h-auto w-full">
        {
          lessons.map((lesson, index) => (
            <TabsTrigger value={index + 1} class="justify-start px-4 py-3 text-left rounded-lg data-[state=active]:bg-linear-to-r data-[state=active]:from-[#D7F4FF] data-[state=active]:to-[#F6FDFF] data-[state=active]:text-foreground hover:bg-muted/50">
              <span class="text-muted-foreground mr-3">{index + 1}.</span>
              <span class="font-medium">{lesson.title}</span>
            </TabsTrigger>
          ))
        }
      </TabsList>

      {
        lessons.map((lesson, index) => (
          <TabsContent value={index + 1} class="bg-muted/50 rounded-xl p-6 mt-0">
            <article class="prose">
               <Markdown of={lesson.content} />
            </article>
          </TabsContent>
        ))
      }
    </Tabs>

    <!-- Mobile: Accordion -->
    <Accordion type="single" defaultValue="1" class="md:hidden">
      {
        lessons.map((lesson, index) => (
          <AccordionItem value={index + 1}>
            <AccordionTrigger>
              <span class="flex items-center">
                <span class="font-medium">{lesson.title}</span>
                {lesson.hasStar && <Star class="ml-2 size-4 text-yellow-500 fill-yellow-500" />}
              </span>
            </AccordionTrigger>
            <AccordionContent>
               <Fragment set:html={index + 1}/>
            </AccordionContent>
          </AccordionItem>
        ))
      }
    </Accordion>
  </div>
</section>

