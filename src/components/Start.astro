---
import { Image } from 'astro:assets';
import Button from './starwind/button';
import { ArrowRight } from '@lucide/astro';
import testStartImage from '@/assets/starts.png';
import data from '@/data/start.yaml';
---

<section class="py-10 lg:py-20">
  <div class="container">
    <div class="bg-[#FFE699] rounded-xl shadow-lg p-6 md:p-8 lg:p-16">
      <div class="flex flex-col md:flex-row justify-between gap-12">
        <div class="flex-1 md:max-w-[512px] flex flex-col justify-between h-auto">
          <div>
            <p class="text-[#2775C9]/80 text-lg font-medium mb-5">{data.counter_text}</p>
            <h2 class="text-2xl md:text-4xl xl:text-5xl font-semibold mb-6 leading-tight">{data.title}</h2>
          </div>
          <div>
            <p class="mb-6 text-foreground/80">{data.description}</p>
            <Button variant="secondary" class="w-full md:w-auto" href={data.cta_url}>{data.cta_text} <ArrowRight /></Button>
          </div>
        </div>
        <div class="flex-1 max-w-md">
          <Image src={testStartImage} alt={data.title} class="w-full" />
        </div>
      </div>
    </div>
  </div>
</section>
