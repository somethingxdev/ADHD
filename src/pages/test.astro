---
import Layout from '@/layouts/Layout.astro';
import { Breadcrumb, BreadcrumbList, BreadcrumbItem, BreadcrumbLink, BreadcrumbSeparator, BreadcrumbPage } from '@/components/starwind/breadcrumb';
import { RadioGroup, RadioGroupItem } from '@/components/starwind/radio-group';
import { Progress } from '@/components/starwind/progress';
import { Card, CardContent } from '@/components/starwind/card';
import Spinner from '@/components/starwind/spinner/Spinner.astro';
import Button from '@/components/starwind/button';
import { Image } from 'astro:assets';
import heroImage from '@/assets/hero.png';
import { ArrowLeft, ArrowRight } from '@lucide/astro';

const questions = [
  {
    id: 1,
    text: 'Как часто вы испытываете трудности с концентрацией на задачах?',
    options: ['Никогда', 'Редко', 'Иногда', 'Часто', 'Очень часто'],
  },
  {
    id: 2,
    text: 'Как часто вы откладываете дела до последнего момента?',
    options: ['Никогда', 'Редко', 'Иногда', 'Часто', 'Очень часто'],
  }
];
---

<Layout>
  <section class="py-6">
    <div class="container">
      <!-- Breadcrumbs -->
      <Breadcrumb class="mb-8">
        <BreadcrumbList>
          <BreadcrumbItem>
            <BreadcrumbLink href="/">Главная</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbPage>Тест на СДВГ</BreadcrumbPage>
          </BreadcrumbItem>
        </BreadcrumbList>
      </Breadcrumb>

      <!-- Quiz section (hidden after completion) -->
      <div id="quiz-section">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 items-start">
          <!-- Left: Quiz card -->
          <Card id="quiz-card">
            <CardContent>
              <div class="flex items-center gap-4 mb-6">
                <span class="text-sm text-muted-foreground whitespace-nowrap" id="question-counter">
                  Вопрос 1 из {questions.length}
                </span>
                <Progress value={Math.round(100 / questions.length)} max={100} variant="primary" class="h-4 max-w-full" id="quiz-progress" />
              </div>

              <!-- Questions container -->
              <div id="questions-container">
                {
                  questions.map((q, idx) => (
                    <div class:list={['question-slide', idx === 0 ? '' : 'hidden']} data-question-index={idx}>
                      <h2 class="text-2xl font-semibold mb-8">{q.text}</h2>
                      <RadioGroup orientation="vertical" id={`radio-group-${idx}`}>
                        {q.options.map((option, optIdx) => (
                          <label class:list={['flex items-center gap-3 px-4 py-5 bg-white cursor-pointer border rounded-xl transition-colors hover:bg-muted/50', 'quiz-option']} data-question={idx}>
                            <RadioGroupItem value={String(optIdx)} name={`question-${idx}`} variant="primary" />
                            <span class="text-base">{option}</span>
                          </label>
                        ))}
                      </RadioGroup>
                    </div>
                  ))
                }
              </div>

              <!-- Navigation -->
              <div class="flex items-center justify-between mt-6 pt-6 border-t border-border">
                <button
                  class="inline-flex items-center gap-2 text-sm font-medium text-muted-foreground hover:text-foreground transition-colors disabled:opacity-40 disabled:cursor-not-allowed"
                  id="btn-prev"
                  disabled>
                  <ArrowLeft class="size-4" />
                  Назад
                </button>
                <Button id="btn-next" class="disabled:opacity-50 disabled:cursor-not-allowed" disabled>
                  Далее
                  <ArrowRight class="size-4" />
                </Button>
              </div>
            </CardContent>
          </Card>

          <!-- Right: Course program stub -->
          <div class="rounded-2xl bg-[#fceabb] p-6 text-center" id="course-sidebar">
            <h3 class="text-lg font-bold mb-4 leading-snug">
              Программа курса<br />по управлению СДВГ
            </h3>
            <Image src={heroImage} alt="Brain character" class="mx-auto mb-6 w-48 h-auto" />
            <Button variant="default" class="w-full"> Приобрести программу </Button>
          </div>
        </div>
      </div>

      <!-- Loader section (shown during calculation) -->
      <div id="loader-section" class="hidden">
        <div class="flex flex-col items-center justify-center py-32">
          <Spinner class="size-12 text-primary mb-6" />
          <p class="text-lg font-medium text-foreground">Анализируем ваши ответы...</p>
          <p class="text-sm text-muted-foreground mt-1">Это займёт несколько секунд</p>
        </div>
      </div>

      <!-- Results section (shown after loader) -->
      <div id="results-section" class="hidden">
        <!-- Result hero card (colored based on result) -->
        <div id="result-hero" class="rounded-2xl p-8 md:p-12 mb-12 relative overflow-hidden min-h-[280px]">
          <div class="relative z-10 max-w-md">
            <h1 id="result-title" class="text-3xl md:text-4xl font-bold mb-4"></h1>
            <p id="result-description" class="text-sm md:text-base mb-6 opacity-80"></p>
            <div class="inline-flex items-center gap-2 rounded-lg border border-black/10 bg-white/20 px-4 py-2 text-sm font-medium">
              <span id="result-score"></span>
            </div>
          </div>
          <!-- TODO: добавить картинку персонажа справа -->
        </div>

        <!-- Course promo block -->
        <div class="flex flex-col items-center py-12">
          <div class="max-w-xl w-full text-center">
            <!-- TODO: добавить картинку мозга слева -->
            <h2 class="text-2xl md:text-3xl font-bold mb-4">Курс поможет вам научиться жить с СДВГ продуктивно</h2>
            <div class="text-left space-y-3 mb-8">
              <p class="font-semibold">Включено:</p>
              <ul class="space-y-2">
                <li class="flex items-center gap-2">
                  <span class="size-2 rounded-full border-2 border-primary shrink-0"></span>
                  7 видео-уроков по управлению СДВГ
                </li>
                <li class="flex items-center gap-2">
                  <span class="size-2 rounded-full border-2 border-primary shrink-0"></span>
                  Практические задания и чек-листы
                </li>
                <li class="flex items-center gap-2">
                  <span class="size-2 rounded-full border-2 border-primary shrink-0"></span>
                  Доступ к закрытому сообществу
                </li>
                <li class="flex items-center gap-2">
                  <span class="size-2 rounded-full border-2 border-primary shrink-0"></span>
                  Поддержка куратора
                </li>
              </ul>
            </div>

            <div class="rounded-xl border border-border p-4 mb-4">
              <p class="font-bold text-lg">Новая цена: 29 ₽ <span class="text-muted-foreground line-through text-sm font-normal">990 ₽</span></p>
              <!-- TODO: добавить таймер обратного отсчёта -->
            </div>

            <Button variant="default" class="w-full text-base h-12"> Получить доступ за 29 ₽ </Button>

            <p class="mt-6 text-xs text-muted-foreground">
              ⚠ Это не медицинский диагноз.<br />Для точной диагностики обратитесь к врачу.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  import { animate } from 'motion/mini';

  const slides = document.querySelectorAll<HTMLElement>('.question-slide');
  const totalQuestions = slides.length;
  let currentQuestion = 0;
  const answers: Record<number, string> = {};

  const counter = document.getElementById('question-counter')!;
  const progressBar = document.querySelector<HTMLElement>('#quiz-progress')!;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const quizSection = document.getElementById('quiz-section')!;
  const loaderSection = document.getElementById('loader-section')!;
  const resultsSection = document.getElementById('results-section')!;

  function updateProgress() {
    const percent = Math.round(((currentQuestion + 1) / totalQuestions) * 100);
    progressBar.setAttribute('data-value', String(percent));
  }

  function updateCounter() {
    counter.textContent = `Вопрос ${currentQuestion + 1} из ${totalQuestions}`;
  }

  function updateNextButton() {
    const hasAnswer = answers[currentQuestion] !== undefined;
    btnNext.disabled = !hasAnswer;
  }

  function updatePrevButton() {
    btnPrev.disabled = currentQuestion === 0;
  }

  async function goToQuestion(newIndex: number, direction: 'forward' | 'backward') {
    if (newIndex < 0 || newIndex >= totalQuestions) return;

    const currentSlide = slides[currentQuestion];
    const nextSlide = slides[newIndex];

    // Animate out current slide
    await animate(currentSlide, { opacity: [1, 0] }, { duration: 0.2, ease: 'easeIn' }).finished;
    currentSlide.style.opacity = '';
    currentSlide.classList.add('hidden');

    // Prepare next slide
    currentQuestion = newIndex;
    nextSlide.classList.remove('hidden');

    // Animate in next slide
    await animate(nextSlide, { opacity: [0, 1] }, { duration: 0.3, ease: 'easeOut' }).finished;
    nextSlide.style.opacity = '';

    updateCounter();
    updateProgress();
    updateNextButton();
    updatePrevButton();
  }

  // Listen for radio changes on all question groups
  slides.forEach((slide, idx) => {
    const radios = slide.querySelectorAll<HTMLInputElement>('input[type="radio"]');
    radios.forEach((radio) => {
      radio.addEventListener('change', () => {
        answers[idx] = radio.value;
        if (idx === currentQuestion) {
          updateNextButton();
        }
        // Highlight selected option
        const labels = slide.querySelectorAll('.quiz-option');
        labels.forEach((label) => {
          label.classList.remove('bg-primary/5', 'border-primary/30');
        });
        const parentLabel = radio.closest('.quiz-option');
        if (parentLabel) {
          parentLabel.classList.add('bg-primary/5', 'border-primary/30');
        }
      });
    });

    // Restore selection highlight if answer exists on revisit
    // (handled by radio group's own checked state)
  });

  btnNext.addEventListener('click', () => {
    if (currentQuestion < totalQuestions - 1) {
      goToQuestion(currentQuestion + 1, 'forward');
    } else {
      showLoader();
    }
  });

  btnPrev.addEventListener('click', () => {
    if (currentQuestion > 0) {
      goToQuestion(currentQuestion - 1, 'backward');
    }
  });

  async function showLoader() {
    // Fade out quiz section
    await animate(quizSection, { opacity: [1, 0] }, { duration: 0.3, ease: 'easeIn' }).finished;
    quizSection.style.display = 'none';

    // Show loader
    loaderSection.style.display = '';
    loaderSection.classList.remove('hidden');
    await animate(loaderSection, { opacity: [0, 1] }, { duration: 0.3, ease: 'easeOut' }).finished;

    // Wait 3-5 seconds
    const delay = 3000 + Math.random() * 2000;
    await new Promise((resolve) => setTimeout(resolve, delay));

    // Fade out loader
    await animate(loaderSection, { opacity: [1, 0] }, { duration: 0.3, ease: 'easeIn' }).finished;
    loaderSection.style.display = 'none';

    // Show results
    showResults();
  }

  function showResults() {
    let totalScore = 0;
    for (const key in answers) {
      totalScore += parseInt(answers[key]);
    }

    // Dynamically compute max score: (number of options - 1) per question
    const firstGroup = slides[0]?.querySelectorAll('input[type="radio"]');
    const optionsPerQuestion = firstGroup ? firstGroup.length : 5;
    const maxScore = totalQuestions * (optionsPerQuestion - 1);

    const resultHero = document.getElementById('result-hero')!;
    const resultTitle = document.getElementById('result-title')!;
    const resultDescription = document.getElementById('result-description')!;
    const resultScore = document.getElementById('result-score')!;

    const percentage = maxScore > 0 ? totalScore / maxScore : 0;

    // 3 levels based on screenshots
    if (percentage <= 0.33) {
      // Низкая
      resultHero.style.backgroundColor = '#3edbd3';
      resultTitle.innerHTML = 'Низкая<br>вероятность СДВГ';
      resultDescription.textContent = 'У вас мало признаков СДВГ. Однако, если вы испытываете трудности с концентрацией или организацией, курс всё равно может быть полезен.';
    } else if (percentage <= 0.66) {
      // Средняя
      resultHero.style.backgroundColor = '#93b5f5';
      resultTitle.innerHTML = 'Средняя<br>вероятность СДВГ';
      resultDescription.textContent = 'У вас есть некоторые признаки СДВГ. Рекомендуем изучить наш курс и при необходимости обратиться к специалисту.';
    } else {
      // Высокая
      resultHero.style.backgroundColor = '#f5a08c';
      resultTitle.innerHTML = 'Высокая<br>вероятность СДВГ';
      resultDescription.textContent = 'У вас много признаков СДВГ. Рекомендуем пройти наш курс и обратиться к врачу для официальной диагностики.';
    }

    resultScore.textContent = `Ваш результат: ${totalScore} из ${maxScore} баллов`;

    resultsSection.style.display = '';
    resultsSection.classList.remove('hidden');
    animate(resultsSection, { opacity: [0, 1] }, { duration: 0.5, ease: 'easeOut' });
  }

  // Initial state
  updateProgress();
  updateCounter();
  updateNextButton();
  updatePrevButton();

  // Animate initial question appearance (opacity only)
  const firstSlide = slides[0];
  if (firstSlide) {
    animate(firstSlide, { opacity: [0, 1] }, { duration: 0.4, ease: 'easeOut' });
  }
</script>
