---
import Layout from '@/layouts/Layout.astro';
import { Breadcrumb, BreadcrumbList, BreadcrumbItem, BreadcrumbLink, BreadcrumbSeparator, BreadcrumbPage } from '@/components/starwind/breadcrumb';
import { RadioGroup, RadioGroupItem } from '@/components/starwind/radio-group';
import { Progress } from '@/components/starwind/progress';
import { Card, CardContent } from '@/components/starwind/card';
import Spinner from '@/components/starwind/spinner/Spinner.astro';
import Button from '@/components/starwind/button';
import CoursePromo from '@/components/CoursePromo.astro';
import { Image } from 'astro:assets';
import { ArrowLeft, ArrowRight } from '@lucide/astro';
import data from '@/data/test.yaml';
import lowResultsImage from '@/assets/low-results.png';
import mediumResultsImage from '@/assets/medium-results.png';
import highResultsImage from '@/assets/hight-results.png';
import buyCourseImage from '@/assets/buy-course.png';

const questions = data.questions;

// Static results
const results = [
  {
    id: 'low',
    title: 'Низкая вероятность СДВГ',
    description: 'У вас мало признаков СДВГ. Однако, если вы испытываете трудности с концентрацией или организацией, курс всё равно может быть полезен.',
    bgColor: 'bg-[#3edbd3]',
    image: lowResultsImage,
  },
  {
    id: 'medium',
    title: 'Средняя вероятность СДВГ',
    description: 'У вас есть некоторые признаки СДВГ. Рекомендуем изучить наш курс и при необходимости обратиться к специалисту.',
    bgColor: 'bg-[#93b5f5]',
    image: mediumResultsImage,
  },
  {
    id: 'high',
    title: 'Высокая вероятность СДВГ',
    description: 'У вас много признаков СДВГ. Рекомендуем пройти наш курс и обратиться к врачу для официальной диагностики.',
    bgColor: 'bg-[#f5a08c]',
    image: highResultsImage,
  },
];
---

<Layout>
  <section class="py-6">
    <div class="container">
      <Breadcrumb class="mb-8">
        <BreadcrumbList>
          <BreadcrumbItem>
            <BreadcrumbLink href="/">Главная</BreadcrumbLink>
          </BreadcrumbItem>
          <BreadcrumbSeparator />
          <BreadcrumbItem>
            <BreadcrumbPage>Тест на СДВГ</BreadcrumbPage>
          </BreadcrumbItem>
        </BreadcrumbList>
      </Breadcrumb>

      <!-- Quiz section (hidden after completion) -->
      <div id="quiz-section">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_320px] gap-8 items-start">
          <!-- Left: Quiz card -->

          <div>
            <Card id="quiz-card" class="md:p-0">
              <CardContent class="md:px-8 md:py-8">
                <div class="flex items-center gap-4 mb-6">
                  <span class="text-sm text-muted-foreground whitespace-nowrap" id="question-counter">
                    Вопрос 1 из {questions.length}
                  </span>
                  <Progress value={0} max={100} variant="primary" class="h-4 max-w-full" id="quiz-progress" />
                </div>

                <!-- Questions container -->
                <div id="questions-container">
                  {
                    questions.map((q, idx) => (
                      <div class:list={['question-slide', idx === 0 ? '' : 'hidden']} data-question-index={idx}>
                        <h2 class="text-xl md:text-2xl font-semibold mb-5 md:mb-8">{q.text}</h2>
                        <RadioGroup orientation="vertical" id={`radio-group-${idx}`}>
                          {q.options.map((option, optIdx) => (
                            <label class:list={['flex items-center gap-3 p-4 bg-white cursor-pointer border rounded-lg transition-colors hover:bg-muted/50', 'quiz-option']} data-question={idx}>
                              <RadioGroupItem value={String(optIdx)} name={`question-${idx}`} variant="primary" />
                              <span class="text-base">{option}</span>
                            </label>
                          ))}
                        </RadioGroup>
                      </div>
                    ))
                  }
                </div>
              </CardContent>
            </Card>

            <!-- Navigation buttons outside card -->
            <div class="flex items-center justify-between mt-6">
              <Button id="btn-prev" variant="outline" disabled>
                <ArrowLeft />
                Назад
              </Button>

              <Button id="btn-next" disabled>
                Далее
                <ArrowRight />
              </Button>
            </div>
          </div>

          <!-- Right: Course program stub -->
          <div class="rounded-2xl bg-[#FFE699] p-6" id="course-sidebar">
            <h3 class="text-2xl font-bold mb-4 leading-snug" set:html={data.sidebar_title}></h3>
            <Image src={buyCourseImage} alt="Brain character" class="mx-auto" />
            <Button variant="default" class="w-full bg-black">{data.sidebar_button}</Button>
          </div>
        </div>
      </div>

      <!-- Loader section (shown during calculation) -->
      <div id="loader-section" class="hidden">
        <div class="flex flex-col items-center justify-center py-32">
          <Spinner class="size-12 text-primary mb-6" />
          <p class="text-lg font-medium text-foreground">{data.loader_text}</p>
          <p class="text-sm text-muted-foreground mt-1">{data.loader_subtext}</p>
        </div>
      </div>

      <!-- Results section (shown after loader) -->
      {
        results.map((result) => (
          <div id={`result-${result.id}`} class:list={['hidden rounded-2xl p-6 md:p-8 xl:p-12 mb-12 overflow-hidden', result.bgColor]}>
            <div class="flex justify-between items-center">
              <div class="relative z-10 md:text-center max-w-[530px] space-y-5">
                <h1 class="text-3xl md:text-4xl lg:text-5xl font-semibold" set:html={result.title} />
                <p class="text-sm md:text-base opacity-80">{result.description}</p>
                <div class="inline-flex items-center gap-2 rounded-lg border border-black/10 bg-white px-4 py-2 font-medium">
                  <span class="result-score"></span>
                </div>
              </div>
              <Image src={result.image} alt={`${result.id} result`} quality={100} class="hidden md:block -mb-12 z-0" />
            </div>
          </div>
        ))
      }

      <div id="course-promo-wrapper" class="hidden mt-10 md:mt-20">
        <CoursePromo />
      </div>
    </div>
  </section>
</Layout>

<script>
  import { animate } from 'motion/mini';

  // Reset all radio buttons on page load
  document.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((radio) => {
    radio.checked = false;
  });

  const slides = document.querySelectorAll<HTMLElement>('.question-slide');
  const totalQuestions = slides.length;
  let currentQuestion = 0;
  const answers: Record<number, string> = {};

  const counter = document.getElementById('question-counter')!;
  const progressBar = document.querySelector<HTMLElement>('#quiz-progress')!;
  const btnNext = document.getElementById('btn-next') as HTMLButtonElement;
  const btnPrev = document.getElementById('btn-prev') as HTMLButtonElement;
  const quizSection = document.getElementById('quiz-section')!;
  const loaderSection = document.getElementById('loader-section')!;

  function updateProgress() {
    const percent = Math.round((currentQuestion / totalQuestions) * 100);
    progressBar.setAttribute('data-value', String(percent));
  }

  function updateCounter() {
    counter.textContent = `Вопрос ${currentQuestion + 1} из ${totalQuestions}`;
  }

  function updateNextButton() {
    const hasAnswer = answers[currentQuestion] !== undefined;
    btnNext.disabled = !hasAnswer;
  }

  function updatePrevButton() {
    btnPrev.disabled = currentQuestion === 0;
  }

  async function goToQuestion(newIndex: number, direction: 'forward' | 'backward') {
    if (newIndex < 0 || newIndex >= totalQuestions) return;

    const currentSlide = slides[currentQuestion];
    const nextSlide = slides[newIndex];

    // Animate out current slide
    await animate(currentSlide, { opacity: [1, 0] }, { duration: 0.2, ease: 'easeIn' }).finished;
    currentSlide.style.opacity = '';
    currentSlide.classList.add('hidden');

    // Prepare next slide
    currentQuestion = newIndex;
    nextSlide.classList.remove('hidden');

    // Animate in next slide
    await animate(nextSlide, { opacity: [0, 1] }, { duration: 0.3, ease: 'easeOut' }).finished;
    nextSlide.style.opacity = '';

    updateCounter();
    updateProgress();
    updateNextButton();
    updatePrevButton();
  }

  // Listen for radio changes on all question groups
  slides.forEach((slide, idx) => {
    const radios = slide.querySelectorAll<HTMLInputElement>('input[type="radio"]');
    radios.forEach((radio) => {
      radio.addEventListener('change', () => {
        answers[idx] = radio.value;
        if (idx === currentQuestion) {
          updateNextButton();
        }
        // Highlight selected option
        const labels = slide.querySelectorAll('.quiz-option');
        labels.forEach((label) => {
          label.classList.remove('bg-primary/5', 'border-primary');
        });
        const parentLabel = radio.closest('.quiz-option');
        if (parentLabel) {
          parentLabel.classList.add('bg-primary/5', 'border-primary');
        }
      });
    });

    // Restore selection highlight if answer exists on revisit
    // (handled by radio group's own checked state)
  });

  btnNext.addEventListener('click', () => {
    if (currentQuestion < totalQuestions - 1) {
      goToQuestion(currentQuestion + 1, 'forward');
    } else {
      showLoader();
    }
  });

  btnPrev.addEventListener('click', () => {
    if (currentQuestion > 0) {
      goToQuestion(currentQuestion - 1, 'backward');
    }
  });

  async function showLoader() {
    // Fade out quiz section
    await animate(quizSection, { opacity: [1, 0] }, { duration: 0.3, ease: 'easeIn' }).finished;
    quizSection.style.display = 'none';

    // Show loader
    loaderSection.style.display = '';
    loaderSection.classList.remove('hidden');
    await animate(loaderSection, { opacity: [0, 1] }, { duration: 0.3, ease: 'easeOut' }).finished;

    // Wait 2-3 seconds
    const delay = 2000 + Math.random() * 1000;
    await new Promise((resolve) => setTimeout(resolve, delay));

    // Fade out loader
    await animate(loaderSection, { opacity: [1, 0] }, { duration: 0.3, ease: 'easeIn' }).finished;
    loaderSection.style.display = 'none';

    // Show results
    showResults();
  }

  async function showResults() {
    // Hide quiz section
    await animate(quizSection, { opacity: [1, 0] }, { duration: 0.3, ease: 'easeIn' }).finished;
    quizSection.style.display = 'none';

    let totalScore = 0;
    for (const key in answers) {
      totalScore += parseInt(answers[key]);
    }

    // Dynamically compute max score: (number of options - 1) per question
    const firstGroup = slides[0]?.querySelectorAll('input[type="radio"]');
    const optionsPerQuestion = firstGroup ? firstGroup.length : 5;
    const maxScore = totalQuestions * (optionsPerQuestion - 1);

    const percentage = maxScore > 0 ? totalScore / maxScore : 0;

    const resultLow = document.getElementById('result-low')!;
    const resultMedium = document.getElementById('result-medium')!;
    const resultHigh = document.getElementById('result-high')!;

    // Hide all result cards first
    resultLow.classList.add('hidden');
    resultMedium.classList.add('hidden');
    resultHigh.classList.add('hidden');

    // Show the appropriate card
    if (percentage <= 0.33) {
      resultLow.classList.remove('hidden');
    } else if (percentage <= 0.66) {
      resultMedium.classList.remove('hidden');
    } else {
      resultHigh.classList.remove('hidden');
    }

    // Set score text on all cards (only visible one matters)
    const scoreText = `Ваш результат: ${totalScore} из ${maxScore} баллов`;
    document.querySelectorAll('.result-score').forEach((el) => {
      el.textContent = scoreText;
    });

    // Show and animate course promo
    const coursePromoWrapper = document.getElementById('course-promo-wrapper')!;
    coursePromoWrapper.classList.remove('hidden');
    await animate(coursePromoWrapper, { opacity: [0, 1], y: [20, 0] }, { duration: 0.4, ease: 'easeOut' }).finished;
  }

  // Initial state
  updateProgress();
  updateCounter();
  updateNextButton();
  updatePrevButton();

  // Animate initial question appearance (opacity only)
  const firstSlide = slides[0];
  if (firstSlide) {
    animate(firstSlide, { opacity: [0, 1] }, { duration: 0.4, ease: 'easeOut' });
  }
</script>
