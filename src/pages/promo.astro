---
import Layout from '@/layouts/Layout.astro';
import { Image } from 'astro:assets';
import { Accordion, AccordionContent, AccordionItem, AccordionTrigger } from '@/components/starwind/accordion';
import { Button } from '@/components/starwind/button';
import Checkbox from '@/components/starwind/checkbox';
import { Card, CardContent } from '@/components/starwind/card';
import { ArrowRight } from '@lucide/astro';
import xMarkImage from '@/assets/xmark.png';

const promoPoints = [
  {
    problem: 'Начинаю 10 дел и не заканчиваю ни одного',
    solution: 'Научитесь доводить до конца',
  },
  {
    problem: 'Забываю всё важное',
    solution: 'Система, которая работает с вашим мозгом',
  },
  {
    problem: 'Думаю, что я просто ленивый',
    solution: 'Узнайте, что на самом деле происходит',
  },
  {
    problem: 'Не могу сосредоточиться дольше 5 минут',
    solution: 'Техники фокуса специально при СДВГ',
  },
];

const reviews = [
  {
    quote: '“Я думала, что просто неорганизованная. Оказалось — у меня СДВГ. После первых двух уроков я наконец поняла, почему не могла закончить ни одно дело. Это перевернуло моё отношение к себе.”',
    name: 'Алина М.',
    city: 'Москва',
    initials: 'АМ',
    accent: 'bg-[#F6D5E8]',
  },
  {
    quote: '“Купил за 29 рублей и не ожидал многого. Теперь рекомендую всем коллегам. Техника "временных блоков" из 3-го урока изменила мою работу полностью.”',
    name: 'Дмитрий К.',
    city: 'Санкт-Петербург',
    initials: 'ДК',
    accent: 'bg-[#D7F0EE]',
  },
  {
    quote: '“Наконец-то объяснение, почему я такая. Не ленивая, не безответственная — просто мой мозг работает по-другому. Курс дал мне инструменты и уверенность в себе.”',
    name: 'Наташа В.',
    city: 'Екатеринбург',
    initials: 'НВ',
    accent: 'bg-[#F8DFC9]',
  },
];

const faqItems = [
  {
    value: 'diagnosis',
    question: 'Это официальный диагноз?',
    answer:
      'Нет. Курс — это образовательный материал, а не медицинская диагностика. Если вы подозреваете у себя СДВГ, мы рекомендуем обратиться к специалисту. Курс поможет вам лучше понять себя и подготовиться к такому разговору с врачом.',
  },
  {
    value: 'without-diagnosis',
    question: 'Подойдёт ли курс, если у меня нет официального диагноза?',
    answer: 'Да. Курс рассчитан и на тех, кто уже получил диагноз, и на тех, кто только узнаёт себя в симптомах и хочет разобраться, что с этим делать в повседневной жизни.',
  },
  {
    value: 'price',
    question: 'Почему так дёшево — 29 рублей?',
    answer: 'Это стартовое предложение, чтобы вы могли спокойно попробовать курс и оценить формат. Дальнейшие условия доступа и продления описаны рядом с кнопкой оплаты.',
  },
  {
    value: 'cancel',
    question: 'Как отменить подписку?',
    answer: 'Подписку можно отменить в личном кабинете. Если возникнут сложности, поддержка поможет быстро отключить продление.',
  },
  {
    value: 'duration',
    question: 'Сколько времени занимает курс?',
    answer: 'Курс состоит из 7 коротких уроков. Большинство учеников проходят материалы в комфортном темпе за 1-2 недели.',
  },
  {
    value: 'refund',
    question: 'Есть ли возврат денег?',
    answer: 'Условия возврата зависят от тарифа и способа оплаты. Актуальные правила лучше вынести в оферту и продублировать рядом с формой покупки.',
  },
];
---

<Layout>
  <section class="pt-24 pb-6">
    <div class="container">
      <div class="flex items-start gap-10 rounded-xl bg-[#41E1DE] p-6 md:p-10 lg:gap-24 lg:p-16 relative">
        <div class="max-w-[534px]">
          <h1 class="text-4xl font-semibold mb-5 text-center">Ваш мозг работает иначе — <br /> и это сила, а не слабость</h1>
          <p class="mb-10 text-center opacity-80">Курс по СДВГ поможет вам наконец сосредоточиться, перестать прокрастинировать и научиться жить в потоке — а не против него.</p>
          <Button variant="secondary" class="w-full mb-4"> Получить доступ к курсу за 29 ₽ <ArrowRight /> </Button>
          <p class="text-xs mb-3 opacity-80">Продолжая, вы соглашаетесь с условиями использования и офертой. Следующее списание — 450 ₽ через 7 дней.</p>
          <div class="flex items-center gap-6">
            <Checkbox id="default" size="sm" label="Я принимаю условия" variant="default" checked />
            <Checkbox id="default2" size="sm" label="Согласен на рассылку" variant="default" checked />
          </div>
        </div>

        <div class="text-center relative z-10">
          {
            promoPoints.map((point, index) => (
              <div class="py-2">
                <Image src={xMarkImage} alt="" aria-hidden="true" class="size-4 mx-auto" />
                <p class="text-muted-foreground">{point.problem}</p>
                <p class="text-xl font-semibold">{point.solution}</p>
              </div>
            ))
          }
        </div>

        <Image src={import('@/assets/promo-heart.png')} class="absolute -right-70 bottom-0 max-w-lg" alt="promo" />
      </div>
    </div>
  </section>

  <section class="py-24">
    <div class="container">
      <div class="grid grid-cols-4 gap-8">
        <div class="space-y-3 text-center">
          <span class="text-4xl font-bold block">12 453</span>
          <p class="text-muted-foreground">человека уже прошли тест</p>
        </div>
        <div class="space-y-3 text-center">
          <span class="text-4xl font-bold block">87%</span>
          <p class="text-muted-foreground">чувствуют результат за 2 недели</p>
        </div>
        <div class="space-y-3 text-center">
          <span class="text-4xl font-bold block">7 уроков</span>
          <p class="text-muted-foreground">практического контента</p>
        </div>
        <div class="space-y-3 text-center">
          <span class="text-4xl font-bold block">4.9 ★</span>
          <p class="text-muted-foreground">средняя оценка курса</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16">
    <div class="container">
      <h2 class="text-5xl font-semibold mb-8 md:max-w-3xl">Почему этот курс работает там, где другие не помогли</h2>
      <div class="grid grid-cols-5 gap-8">
        <div class="p-10 rounded-xl col-span-2 overflow-hidden relative min-h-[375px]" style="background: linear-gradient(180deg, #FFCCFA 0%, #FFE9FD 100%);">
          <h3 class="text-2xl font-semibold mb-2">Создан специально при СДВГ</h3>
          <p class="text-xl text-muted-foreground z-5">Не просто советы по продуктивности. Каждый урок разработан с учётом того, как работает мозг с СДВГ — короткие модули, без воды, с практикой.</p>
          <div class="absolute bottom-0 right-0 scale-110">
            <Image src={import('@/assets/promo-work/1.png')} alt="promo" class="w-full" />
          </div>
        </div>
        <div class="p-10 rounded-xl col-span-3 overflow-hidden relative min-h-[375px]" style="background: linear-gradient(180deg, #FFE699 0%, #FFF5D7 100%);">
          <h3 class="text-2xl font-semibold mb-2">Без диагноза — можно начинать сейчас</h3>
          <p class="text-xl text-muted-foreground z-5">Не нужно ждать врача или официальной диагностики. Курс подходит всем, кто узнал себя в симптомах.</p>
          <div class="absolute bottom-0 left-0 right-0">
            <Image src={import('@/assets/promo-work/2.png')} alt="promo" />
          </div>
        </div>
        <div class="p-10 rounded-xl col-span-3 overflow-hidden relative min-h-[170px]" style="background: linear-gradient(180deg, #B0E8FD 0%, #E4F8FF 100%);">
          <h3 class="text-2xl font-semibold mb-2">Реальные инструменты, а не теория</h3>
          <p class="text-xl text-muted-foreground z-5 max-w-[310px]">Каждый урок заканчивается конкретным заданием. Вы сразу применяете знания в жизни.</p>
          <div class="absolute bottom-0 right-20">
            <Image src={import('@/assets/promo-work/3.png')} alt="promo" />
          </div>
        </div>
        <div class="p-10 rounded-xl col-span-2 overflow-hidden relative min-h-[170px]" style="background: linear-gradient(180deg, #FFCCFA 0%, #FFE9FD 100%);">
          <h3 class="text-2xl font-semibold mb-2">Учитесь в своём темпе</h3>
          <p class="text-xl text-muted-foreground z-5">Никаких дедлайнов. Открывайте уроки когда удобно — утром, в обед или в 2 ночи.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container">
      <h2 class="mb-10 text-center text-3xl font-semibold md:mb-12 md:text-5xl">Они уже сделали это</h2>
      <div class="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
        {
          reviews.map((review) => (
            <Card class="min-h-[256px] bg-white border border-border">
              <CardContent class="flex h-full flex-col justify-between">
                <p class="mb-6">{review.quote}</p>

                <div class="flex items-center gap-3">
                  <div class:list={['flex size-10 shrink-0 items-center justify-center rounded-full text-xs font-semibold text-foreground', review.accent]}>{review.initials}</div>
                  <div class="space-y-0.5">
                    <p class="text-sm font-medium leading-none">{review.name}</p>
                    <p class="text-sm text-muted-foreground">
                      {review.city}
                      <span class="ml-1 tracking-[0.18em] text-foreground/70">★★★★★</span>
                    </p>
                  </div>
                </div>
              </CardContent>
            </Card>
          ))
        }
      </div>
    </div>
  </section>

  <section class="py-12 md:py-24 bg-[#EF4F27]">
    <div class="container">
      <div class="flex justify-between items-center">
        <h2 class="max-w-[540px] text-3xl font-bold md:text-4xl text-primary-foreground">Только сейчас — бесплатный бонус при оплате сегодня</h2>
        <div class="rounded-md border border-white/30 bg-[#F07C5D] p-4 md:p-5 max-w-[565px]">
          <p class="text-lg font-bold md:text-2xl text-primary-foreground mb-4">🎁 PDF-гайд: «10 техник фокуса при СДВГ»</p>
          <p class="text-primary-foreground">Практическое руководство, которое вы сможете применить прямо сегодня. Стоимость — 490 ₽. Ваша цена — бесплатно.</p>
          <button type="button" class="mt-5 h-11 w-full rounded-md bg-white px-4 text-sm font-medium text-[#EC6D4A] transition-opacity hover:opacity-90"> Забрать бесплатно </button>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="container">
      <h2 class="mb-10 text-center text-4xl font-semibold md:mb-12 md:text-[56px]">FAQ</h2>

      <div class="mx-auto max-w-[640px]">
        <Accordion type="single" defaultValue="diagnosis" class="w-full">
          {
            faqItems.map((item) => (
              <AccordionItem value={item.value} class="border-[#E6E6E6]">
                <AccordionTrigger class="py-4 text-base font-medium md:text-xl">{item.question}</AccordionTrigger>
                <AccordionContent class="text-sm leading-6 text-muted-foreground md:text-base">{item.answer}</AccordionContent>
              </AccordionItem>
            ))
          }
        </Accordion>
      </div>
    </div>
  </section>

  <section
    class="py-16 md:py-24"
    style="background: linear-gradient(0deg, var(--alpha-40, rgba(255, 255, 255, 0.60)) 0%, var(--alpha-40, rgba(255, 255, 255, 0.60)) 100%), var(--base-muted, #F4F4F5);">
    <div class="container">
      <div class="mx-auto max-w-[680px] text-center">
        <h2 class="text-4xl font-semibold leading-tight md:text-[60px] md:leading-[1.08]">Ваш мозг заслуживает понимания</h2>
        <p class="mx-auto mt-6 max-w-[574px] text-lg text-muted-foreground md:text-base">
          Тысячи людей с СДВГ уже изменили свою жизнь. Не потому что стали другими — а потому что наконец поняли себя. Начните сегодня — за 29 ₽.
        </p>
        <Button class="mt-8 bg-[#2FA89A] px-6 hover:bg-[#289486]">
          Получить доступ к курсу
          <ArrowRight />
        </Button>
      </div>
    </div>
  </section>
</Layout>
